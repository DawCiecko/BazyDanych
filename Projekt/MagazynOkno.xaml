<Window x:Class="Projekt.MagazynOkno"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt"
        mc:Ignorable="d"
        Title="MagazynOkno" Height="450" Width="800">
    <Grid>
        <Border BorderBrush="Black" BorderThickness="1" Margin="10,217,173,10"/>

        <Border BorderBrush="Black" BorderThickness="1" Margin="10,10,173,222"/>

        <Label Content="Stany Magazynowe" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Dostawy" HorizontalAlignment="Left" Margin="10,217,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="LBStanyMagazynowe" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,36,173,222"/>
        <ListBox x:Name="LBDostawy" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,248,173,10"/>

    </Grid>
</Window>
