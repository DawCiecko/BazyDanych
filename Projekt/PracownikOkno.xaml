<Window x:Class="Projekt.PracownikOkno"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt"
        mc:Ignorable="d"
        Title="PracownikOkno" Height="450" Width="800">
    <Grid>
        <Border BorderBrush="Black" BorderThickness="1" Margin="10,80,182,64"/>

        <Border BorderBrush="Black" BorderThickness="1" Margin="9,10,182,367"/>

        <Label Content="Pesel:" HorizontalAlignment="Left" Margin="9,8,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LABELPESEL" Content="00000000000" HorizontalAlignment="Left" Margin="53,10,0,0" VerticalAlignment="Top"/>
        <Label Content="NR Telefonu:" HorizontalAlignment="Left" Margin="9,41,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LABELNRTelefonu" Content="000 000 000" HorizontalAlignment="Left" Margin="91,41,0,0" VerticalAlignment="Top"/>
        <Label Content="Imię:" HorizontalAlignment="Left" Margin="207,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Nazwisko:" HorizontalAlignment="Left" Margin="207,41,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LABELImie" Content="Jan" HorizontalAlignment="Left" Margin="275,10,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LABELNazwisko" Content="Kowalski" HorizontalAlignment="Left" Margin="275,41,0,0" VerticalAlignment="Top"/>
        <Label Content="Adres Zamieszkania:" HorizontalAlignment="Left" Margin="363,10,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LABELAdres" Content="Ulica Ulicowa 10" HorizontalAlignment="Left" Margin="485,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Stanowisko:" HorizontalAlignment="Center" Margin="0,39,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LABELStanowisko" Content="pracownik" HorizontalAlignment="Left" Margin="441,39,0,0" VerticalAlignment="Top"/>
        <Label Content="Grafik" HorizontalAlignment="Left" Margin="10,80,0,0" VerticalAlignment="Top" Width="608"/>
        <ListBox x:Name="LBGrafik" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,106,182,64"/>
        <Button x:Name="BTNMagazyn" Content="Magazyn" HorizontalAlignment="Left" Margin="10,375,0,0" VerticalAlignment="Top" Height="49" Width="124" Click="BTNMagazyn_Clicked"/>

    </Grid>
</Window>
