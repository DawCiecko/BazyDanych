<Window x:Class="Projekt.Widok"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt"
        mc:Ignorable="d"
        Title="Widok" Height="545" Width="859">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="37*"/>
        </Grid.RowDefinitions>
        <Label x:Name="lbl_hello" Content="Witaj xyz" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <Border BorderBrush="Black" BorderThickness="1" Margin="10,41,0,10" Grid.RowSpan="2" HorizontalAlignment="Left" Width="137">
            <Grid x:Name="grid_btn_cat" Margin="9,9,9,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition Width="0*"/>
                </Grid.ColumnDefinitions>
            </Grid>
        </Border>
        <Border x:Name="window_sub_listbox_col2" BorderBrush="Black" BorderThickness="1" Margin="147,41,0,10" Grid.RowSpan="2" Visibility="Collapsed" HorizontalAlignment="Left" Width="167">
            <Grid Margin="9,9,9,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="42*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lbl_2kol" Content="Label" Margin="10,10,10,0" VerticalAlignment="Top" Grid.Column="1" Height="26" Grid.ColumnSpan="2"/>
                <ListBox x:Name="lsbx_2kol" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,63,10,10" Grid.ColumnSpan="3"/>
                <ComboBox x:Name="cmbx_kol2" Grid.Column="1" HorizontalAlignment="Left" Margin="10,36,0,0" VerticalAlignment="Top" Width="127" Grid.ColumnSpan="2"/>
            </Grid>
        </Border>
        <Border x:Name="window_action_panel" BorderBrush="Black" BorderThickness="1" Margin="319,41,0,10" Grid.RowSpan="2" Visibility="Collapsed" HorizontalAlignment="Left" Width="300">
            <StackPanel Margin="10,10,10,10">
                <Label x:Name="lbl_action_title" Content="Action" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label x:Name="lbl_input1" Content="Input 1:" Visibility="Collapsed"/>
                <TextBox x:Name="tb_input1" Height="25" Visibility="Collapsed" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbx_action_input1" Height="25" Visibility="Collapsed" Margin="0,0,0,5"/>
                <Label x:Name="lbl_input2" Content="Input 2:" Visibility="Collapsed"/>
                <TextBox x:Name="tb_input2" Height="25" Visibility="Collapsed" Margin="0,0,0,5"/>
                <Label x:Name="lbl_input3" Content="Input 3:" Visibility="Collapsed"/>
                <TextBox x:Name="tb_input3" Height="25" Visibility="Collapsed" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbx_action_input3" Height="25" Visibility="Collapsed" Margin="0,0,0,15"/>
                <Button x:Name="btn_action" Content="Zatwierdź" Height="35" Width="120" Visibility="Collapsed" Click="On_btn_action_Click"/>
                <ListBox x:Name="lsbx_action" Height="350" Visibility="Collapsed" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
